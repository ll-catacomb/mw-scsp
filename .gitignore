# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg

# --- uv / venv ---
.venv/
.python-version
uv.lock

# --- env ---
.env
.env.*
!.env.example

# --- editor / OS ---
.vscode/
.idea/
.DS_Store

# --- pytest / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/
.ruff_cache/
.mypy_cache/

# --- project data (per PROJECT_SPEC.md §8) ---
data/doctrine/raw/
data/memory.db
data/memory.db-journal
data/memory.db-wal
data/memory.db-shm
data/runs/

# Keep the data/ tree readable but ignore large/secret content.
# data/doctrine/passages/ IS tracked (curated markdown corpus, see SCHEMA.md).
!data/
!data/doctrine/
!data/doctrine/passages/
!data/doctrine/passages/**
!data/doctrine/.gitkeep

# --- streamlit ---
.streamlit/secrets.toml

# --- logs ---
*.log
logs/
