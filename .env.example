# Copy to .env and fill in. .env is .gitignored.

# Provider API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Models (current as of RA-6 / 2026-04). Override in code; wrapper reads these as defaults.
# Pinning policy: only Haiku has a snapshot string available; Opus 4.7 / Sonnet 4.6 / GPT-5.5
# are floating aliases.
MODAL_CLAUDE_MODEL=claude-sonnet-4-6
MODAL_GPT_MODEL=gpt-5.5
HEAVY_CLAUDE_MODEL=claude-opus-4-7
JUDGE_CLAUDE_MODEL=claude-haiku-4-5-20251001
JUDGE_GPT_MODEL=gpt-5

# Cost guardrails (USD). logged_completion() raises CostCapExceeded past these.
# RA-6 estimates ~$0.40 / run on the realistic mix; $1.10 = 1.5× headroom for runaway prompts.
RUN_COST_CAP_USD=1.10
TOTAL_COST_CAP_USD=50.00

# Per-provider concurrency (per RA-6 §"Concurrency strategy"). Anthropic T1 50 RPM,
# OpenAI T1 ~1000 RPM — independent buckets, separate semaphores.
ANTHROPIC_MAX_CONCURRENCY=8
OPENAI_MAX_CONCURRENCY=16

# Data paths (relative to repo root)
MEMORY_DB_PATH=data/memory.db
DOCTRINE_PASSAGES_DIR=data/doctrine/passages
RUN_ARTIFACTS_DIR=data/runs

# Memory uses sentence-transformers for relevance (cosine similarity).
# Doctrine does NOT use embeddings — markdown corpus + frontmatter index instead (PROJECT_SPEC.md §5).
MEMORY_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
MEMORY_QUERY_PREFIX="Represent this sentence for searching relevant passages: "
